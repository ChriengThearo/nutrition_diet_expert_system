# Required
SECRET_KEY=change-me

# Preferred for production (Postgres/Supabase)
DATABASE_URL=postgresql://user:password@host:5432/dbname
# SUPABASE_DB_URL=postgresql://user:password@host:5432/dbname

# Optional runtime flags
SKIP_DB_CREATE_ALL=1
SESSION_COOKIE_SECURE=1
REMEMBER_COOKIE_SECURE=1

# Optional cloud OCR (recommended for Vercel serverless)
# Azure AI Vision OCR (recommended primary provider)
# AZURE_VISION_ENDPOINT=https://<your-resource-name>.cognitiveservices.azure.com
# AZURE_VISION_KEY=your-azure-vision-key
# AZURE_OCR_LANGUAGE=en
# AZURE_OCR_POLL_INTERVAL_SECONDS=1.2
# AZURE_OCR_MAX_POLLS=20
#
# OCR.Space fallback provider
# OCR_SPACE_API_KEY=your-ocr-space-api-key
# OCR_SPACE_ENDPOINT=https://api.ocr.space/parse/image
# OCR_SPACE_LANGUAGE=eng
# OCR_SPACE_ENGINE=2
# OCR_HTTP_TIMEOUT=45

# Optional if you use schema-specific Postgres setup
# DB_SCHEMA=public

# Fallback MySQL settings (used only when DATABASE_URL is not set)
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=mysql
# DB_NAME=expert_system_test3
# DB_PORT=3306
