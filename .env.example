# Required
SECRET_KEY=change-me

# Preferred for production (Postgres/Supabase)
DATABASE_URL=postgresql://user:password@host:5432/dbname
# SUPABASE_DB_URL=postgresql://user:password@host:5432/dbname

# Optional runtime flags
SKIP_DB_CREATE_ALL=1
SESSION_COOKIE_SECURE=1
REMEMBER_COOKIE_SECURE=1

# Optional if you use schema-specific Postgres setup
# DB_SCHEMA=public

# Fallback MySQL settings (used only when DATABASE_URL is not set)
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=mysql
# DB_NAME=expert_system_test3
# DB_PORT=3306
